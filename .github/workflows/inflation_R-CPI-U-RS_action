# This workflow pulls new R-CPI-U-RS inflation data

on:
  schedule:
    - cron: '1 1 1 3,4,5,9 *'

  workflow_dispatch:

name: pull R-CPI-U-RS research series

env:
  BLS_KEY: ${{ secrets.BLS_KEY }}

jobs:
  render:
    name: Gather latest inflation data
    runs-on: macos-latest
    steps:
      - uses: actions/checkout@v4
      - uses: r-lib/actions/setup-r@v2
      - name: Set up pandoc for Rmd docs
        uses: r-lib/actions/setup-pandoc@v2
      - name: Install dependencies and packages
        run: Rscript -e 'install.packages(c("tidyverse","blscrapeR","janitor","dplyr","lubridate","stringr","blsR","r2r","httr2","readxl"))'
      - name: pull data, export file
        run: Rscript scripts/R-CPI-U-RS_data_collection.R
      - name: Commit results
        run: |
          git add -A
          git commit -m 'New inflation data' || echo "No changes"
          git push origin || echo "No changes to commit"
